      font-size: 1.1rem;
      color: var(--white);
      line-height: 1.2;
    }

    .fact-sub {
      font-size: 0.8rem;
      color: var(--mid);
      margin-top: 0.2rem;
    }

    /* ── TEXTE ── */
    .downloads {
      border-bottom: 1px solid var(--rule);
    }

    .download-item {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      padding: 1.4rem 0;
      border-bottom: 1px solid var(--rule);
      text-decoration: none;
      color: var(--white);
      transition: background 0.12s;
    }

    .download-item:last-child { border-bottom: none; }
