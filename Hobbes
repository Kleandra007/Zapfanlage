    .dl-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.9rem;
      color: var(--mid);
      width: 2.5rem;
      flex-shrink: 0;
    }

    .dl-title {
      font-size: 1rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 0.2rem;
    }

    .dl-meta {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--mid);
    }

    .dl-arrow {
      margin-left: auto;
      font-size: 1.1rem;
      color: var(--mid);
      flex-shrink: 0;
    }

    /* ── FRAGEN ── */
    .fragen {
      border-bottom: 1px solid var(--rule);
    }

    .frage {
      padding: 2rem 0;
      border-bottom: 1px solid var(--rule);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .frage:last-child { border-bottom: none; }

