  <style>
    :root {
      --black: #1c1c1e;
      --white: #f2f2f0;
      --mid: #888;
      --rule: #2a2a2a;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Urbanist', Arial, sans-serif;
      min-height: 100vh;
    }

    a { color: inherit; }

    /* ── NAV ── */
    nav {
      border-bottom: 1px solid var(--rule);
      padding: 1rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--black);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .nav-home {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      letter-spacing: 0.05em;
      color: var(--white);
      text-decoration: none;
    }

    .nav-home span { color: var(--mid); }

    .nav-back {
      font-size: 0.7rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--mid);
      text-decoration: none;
      transition: color 0.15s;
    }

    .nav-back:hover { color: var(--white); }

    /* ── HEADER ── */
    header {
      border-bottom: 1px solid var(--rule);
      position: relative;
      overflow: hidden;
    }

    header::before {
      content: '01';
      position: absolute;
      right: -0.05em;
      top: -0.1em;
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(14rem, 32vw, 24rem);
      color: rgba(255,255,255,0.025);
      line-height: 1;
      pointer-events: none;
      user-select: none;
    }

    .header-inner {
      padding: 3rem 2.5rem 2rem;
      max-width: 1000px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1fr 220px;
      gap: 3rem;
      align-items: end;
    }

    .header-text {}

    .header-portrait {
      position: relative;
    }

    .header-portrait img {
      width: 100%;
      display: block;
      filter: grayscale(100%) contrast(1.1);
      opacity: 0.85;
    }

    .header-portrait figcaption {
      font-size: 0.6rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #555;
      margin-top: 0.5rem;
      line-height: 1.4;
    }

    .eyebrow {
      font-size: 0.62rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--mid);
      margin-bottom: 1rem;
    }

    .author-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3rem, 10vw, 7rem);
      line-height: 0.9;
      color: var(--white);
    }

    .author-subtitle {
      font-size: 1rem;
      color: var(--mid);
      margin-top: 1rem;
      letter-spacing: 0.05em;
    }

    .header-bar {
      border-top: 1px solid var(--rule);
      background: #242426;
    }

    .header-bar-inner {
      max-width: 1000px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
    }

    .header-bar .item {
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.9rem 2rem;
      border-right: 1px solid var(--rule);
    }

    .header-bar .item span { color: var(--mid); }
    .header-bar .item strong { color: var(--white); font-weight: 700; }

    /* ── MAIN ── */
    main {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 2.5rem 6rem;
    }

    /* ── SECTION HEADS ── */
    .section-head {
      display: flex;
      align-items: baseline;
      gap: 1.2rem;
      padding: 2.5rem 0 1.2rem;
      border-bottom: 1px solid var(--rule);
      margin-bottom: 0;
    }

    .section-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.9rem;
      color: var(--mid);
      letter-spacing: 0.1em;
    }

    .section-head h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 0.04em;
      color: var(--white);
      font-weight: 400;
    }

    /* ── BIO ── */
    .bio {
      display: grid;
      grid-template-columns: 1fr 260px;
      gap: 0;
      border-bottom: 1px solid var(--rule);
    }

    @media (max-width: 680px) {
      .bio { grid-template-columns: 1fr; }
      .bio-facts { border-left: none; border-top: 1px solid var(--rule); }
    }

    .bio-text {
      padding: 2.5rem 3rem 2.5rem 0;
      border-right: 1px solid var(--rule);
    }

    .bio-text p {
      font-size: 1rem;
      line-height: 1.8;
      color: #ccc;
      margin-bottom: 1rem;
