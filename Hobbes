    .fact {
      margin-bottom: 1.5rem;
    }

    .fact-label {
      font-size: 0.6rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--mid);
      margin-bottom: 0.3rem;
    }

