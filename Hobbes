      line-height: 1.75;
      color: #ccc;
      max-width: 700px;
    }

    .krise-text em { color: var(--white); font-style: italic; }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--rule);
      padding: 2rem 2.5rem;
      text-align: center;
    }

    .f-title {
